# Copy this file to .env.qdrant in the repo root and chmod it to 600.
# Do not commit .env.qdrant.
#
# Generate separate values for both secrets, for example:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# Qdrant server configuration. These are read by the Qdrant container.
QDRANT__SERVICE__API_KEY="replace-with-random-write-token"
QDRANT__SERVICE__READ_ONLY_API_KEY="replace-with-random-read-only-token"
QDRANT__TELEMETRY_DISABLED="true"

# Local client/script aliases. Keep these aligned with the Qdrant server values above.
QDRANT_API_KEY="replace-with-random-write-token"
QDRANT_READ_ONLY_API_KEY="replace-with-random-read-only-token"
QDRANT_URL="http://127.0.0.1:6333"

# Starter collection defaults.
MANAGER_OPENBRAIN_MEMORY_COLLECTION="manager_openbrain_memory_v1"
MANAGER_OPENBRAIN_VECTOR_SIZE="384"
MANAGER_OPENBRAIN_VECTOR_DISTANCE="Cosine"
MANAGER_OPENBRAIN_QDRANT_CONTAINER="manager-openbrain-qdrant"
