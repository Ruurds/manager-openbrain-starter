{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Ruurds/manager-openbrain-starter/schemas/mcp-tool-surface-audit.schema.json",
  "title": "MCP Tool Surface Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reportDate",
    "client",
    "workingDirectory",
    "targetWorkflow",
    "mode",
    "executiveSummary",
    "toolSurfaceSummary",
    "overlapAndRoutingRisks",
    "recommendedActiveSurface",
    "followUpChecks",
    "memoryProposal"
  ],
  "properties": {
    "reportDate": { "type": "string", "format": "date" },
    "client": { "type": "string", "enum": ["claude", "codex", "both"] },
    "workingDirectory": { "type": "string", "minLength": 1 },
    "targetWorkflow": { "type": "string", "minLength": 1 },
    "mode": { "const": "read-only inventory" },
    "executiveSummary": { "type": "string", "minLength": 1 },
    "toolSurfaceSummary": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceSummary" }
    },
    "overlapAndRoutingRisks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recommendedActiveSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keepActive", "disableForThisWorkflow", "adminOnlyApprovalRequired"],
      "properties": {
        "keepActive": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "disableForThisWorkflow": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "adminOnlyApprovalRequired": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "followUpChecks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "memoryProposal": { "$ref": "#/$defs/memoryProposal" }
  },
  "$defs": {
    "sourceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "client",
        "toolCount",
        "read",
        "write",
        "admin",
        "local",
        "unknown",
        "risk"
      ],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "client": { "type": "string", "enum": ["claude", "codex", "both", "unknown"] },
        "toolCount": { "type": "integer", "minimum": 0 },
        "read": { "type": "integer", "minimum": 0 },
        "write": { "type": "integer", "minimum": 0 },
        "admin": { "type": "integer", "minimum": 0 },
        "local": { "type": "integer", "minimum": 0 },
        "unknown": { "type": "integer", "minimum": 0 },
        "risk": { "type": "string", "enum": ["low", "medium", "high", "very high"] },
        "notes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "memoryProposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suggestedStatus", "supersedes", "store", "executed"],
      "properties": {
        "suggestedStatus": {
          "type": "string",
          "enum": ["active", "needs_review", "superseded", "deprecated", "archived", "wrong", "hard_deleted"]
        },
        "supersedes": { "type": ["string", "null"] },
        "store": { "type": "string" },
        "executed": { "const": false }
      }
    }
  }
}
